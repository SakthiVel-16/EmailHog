# Environment Variables Template
# ⚠️  IMPORTANT: This file contains PLACEHOLDER values ONLY!
# Do NOT add real credentials here - it will be committed to GitHub!
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. REPLACE all PLACEHOLDER values below with YOUR actual credentials
# 3. .env file is in .gitignore - it will NOT be committed to GitHub
# 4. NEVER commit real credentials to ANY .example file!

# ===== MONGODB ATLAS =====
# Get your MongoDB Connection String from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/?appName=app-name
# PLACEHOLDER - Replace with your actual MongoDB URI
MONGODB_URI=YOUR_MONGODB_URI_HERE
MONGODB_DATABASE=emailhog

# ===== GOOGLE GEMINI API =====
# Get your API key from: https://aistudio.google.com
# PLACEHOLDER - Replace with your actual Gemini API key
GEMINI_API_KEY=YOUR_ACTUAL_GEMINI_API_KEY_HERE

# ===== SPRING PROFILES (Optional) =====
SPRING_PROFILES_ACTIVE=local
