# Environment Variables Template
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. REPLACE all placeholder values with YOUR actual credentials
# 3. .env file is in .gitignore - it will NOT be committed to GitHub
# ⚠️  NEVER add actual credentials to this .env.example file!

# ===== MONGODB ATLAS =====
# Get your MongoDB Connection String from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/?appName=app-name
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=your-app-name
MONGODB_DATABASE=emailhog

# ===== GOOGLE GEMINI API =====
# Get your API key from: https://aistudio.google.com
# WARNING: This is a placeholder - replace with YOUR actual key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ===== SPRING PROFILES =====
# Use 'local' for development with application-local.properties
SPRING_PROFILES_ACTIVE=local
